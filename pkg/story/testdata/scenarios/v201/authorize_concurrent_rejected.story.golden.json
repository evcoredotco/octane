          }
        },
        {
          "Kind": 4,
          "Text": "the CSMS authorizes id token \"VID:0001\" for station \"CP01\"",
          "Position": {
            "Line": 29,
            "Column": 5
          }
        },
        {
          "Kind": 6,
          "Text": "Parallel",
          "Position": {
            "Line": 30,
            "Column": 5
          }
        },
        {
          "Kind": 2,
          "Text": "station \"CP02\" sends Authorize with id token \"VID:0001\"",
          "Position": {
            "Line": 31,
            "Column": 9
          }
        },
        {
          "Kind": 6,
          "Text": "End-Parallel",
          "Position": {
            "Line": 32,
            "Column": 5
          }
        },
        {
          "Kind": 3,
          "Text": "the CSMS rejects \"CP02\" with status \"ConcurrentTx\"",
          "Position": {
            "Line": 33,
            "Column": 5
          }
        },
        {
          "Kind": 4,
          "Text": "station \"CP01\"'s transaction remains active",
