      "name": "Plug-in precedes authorization; transaction starts cleanly",
      "steps": [
        {
          "kind": 2,
          "text": "station \"CP01\" sends StatusNotification for connector {connectorId} with status \"Preparing\"",
          "position": {
            "line": 55,
            "column": 5
          }
        },
        {
          "kind": 3,
          "text": "the CSMS acknowledges the status within 10 seconds",
          "position": {
            "line": 56,
            "column": 5
          }
        },
        {
          "kind": 2,
          "text": "station \"CP01\" sends Authorize with idTag \"{idTag}\"",
          "position": {
            "line": 58,
            "column": 5
          }
        },
        {
          "kind": 3,
          "text": "the CSMS responds to Authorize with idTagInfo.status \"Accepted\" within 30 seconds",
          "position": {
            "line": 59,
            "column": 5
          }
        },
        {
          "kind": 2,
          "text": "station \"CP01\" starts a transaction on connector {connectorId} with idTag \"{idTag}\" and meterStart {meterStart}",
          "position": {
            "line": 61,
            "column": 5
          }
        },
        {
          "kind": 3,
          "text": "the CSMS responds to StartTransaction with idTagInfo.status \"Accepted\" within 30 seconds",
          "position": {
            "line": 62,
            "column": 5
          }
        },
        {
          "kind": 4,
          "text": "the StartTransaction response assigns a positive transactionId",
          "position": {
            "line": 63,
            "column": 5
          }
        },
        {
          "kind": 2,
          "text": "station \"CP01\" sends StatusNotification for connector {connectorId} with status \"Charging\"",
          "position": {
            "line": 65,
            "column": 5
          }
        },
        {
          "kind": 3,
          "text": "the CSMS acknowledges the status within 10 seconds",
