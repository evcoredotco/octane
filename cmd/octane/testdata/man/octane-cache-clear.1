.SH NAME
octane-cache-clear - Remove all entries from the result cache


.SH SYNOPSIS
\fBoctane cache clear [flags]\fP


.SH DESCRIPTION
clear removes the contents of the results/ subdirectory in the
cache directory, effectively invalidating all cached test results.

.PP
The cache directory structure itself (version.json, locks/) is
preserved; only result entries are removed.


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for clear


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--cache-dir\fP=""
	override the cache directory (default: $XDG_CACHE_HOME/octane/cache)

.PP
\fB--config\fP="octane.yml"
	path to octane.yml configuration file

.PP
\fB--no-cache\fP[=false]
	bypass the result cache entirely

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	enable verbose output


.SH SEE ALSO
\fBoctane-cache(1)\fP


