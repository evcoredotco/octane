.SH NAME
octane-completion - Generate shell completion scripts


.SH SYNOPSIS
\fBoctane completion [bash|zsh|fish|powershell] [flags]\fP


.SH DESCRIPTION
Generate shell completion scripts for octane.

.PP
To load completions in the current shell session:

.PP
Bash:
    source <(octane completion bash)

.PP
Zsh:
    source <(octane completion zsh)

.PP
Fish:
    octane completion fish | source

.PP
PowerShell:
    octane completion powershell | Out-String | Invoke-Expression


.SH OPTIONS
\fB-h\fP, \fB--help\fP[=false]
	help for completion


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--cache-dir\fP=""
	override the cache directory (default: $XDG_CACHE_HOME/octane/cache)

.PP
\fB--config\fP="octane.yml"
	path to octane.yml configuration file

.PP
\fB--no-cache\fP[=false]
	bypass the result cache entirely

.PP
\fB-v\fP, \fB--verbose\fP[=false]
	enable verbose output


.SH SEE ALSO
\fBoctane(1)\fP


